<style>
*{box-sizing:border-box;margin:0;padding:0}
.wrap{padding:28px 20px;font-family:var(--font-sans)}

.db-section{margin-bottom:28px}
.db-header{display:flex;align-items:center;gap:12px;margin-bottom:14px;padding-bottom:10px;border-bottom:1.5px solid var(--color-border-tertiary)}
.db-icon{width:42px;height:42px;flex-shrink:0}
.db-title{font-size:15px;font-weight:500;color:var(--color-text-primary)}
.db-sub{font-size:11px;color:var(--color-text-secondary);margin-top:2px}
.db-badge{display:inline-block;font-size:9px;font-weight:500;padding:2px 8px;border-radius:99px;margin-top:3px}
.badge-teal{background:#1D9E75;color:#E1F5EE}
.badge-blue{background:#185FA5;color:#E6F1FB}
.badge-green{background:#3B6D11;color:#EAF3DE}

.qgrid{display:flex;flex-direction:column;gap:12px}
.qcard{border-radius:13px;overflow:hidden;border:1.5px solid}
.qcard.teal{border-color:#9FE1CB;background:#E1F5EE}
.qcard.blue{border-color:#B5D4F4;background:#E6F1FB}
.qcard.green{border-color:#C0DD97;background:#EAF3DE}

.qcard-head{display:flex;align-items:center;gap:10px;padding:12px 14px 8px}
.qnum{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;font-weight:500}
.qnum.teal{background:#1D9E75;color:#E1F5EE}
.qnum.blue{background:#185FA5;color:#E6F1FB}
.qnum.green{background:#3B6D11;color:#EAF3DE}
.qcard-head h3{font-size:12px;font-weight:500;color:var(--color-text-primary)}
.qcard-head code{font-size:10px;color:var(--color-text-secondary);font-family:var(--font-mono);margin-left:auto;white-space:nowrap}

.qcard-body{display:flex;gap:0;border-top:1px solid}
.qcard.teal .qcard-body{border-color:#9FE1CB}
.qcard.blue .qcard-body{border-color:#B5D4F4}
.qcard.green .qcard-body{border-color:#C0DD97}

.insights{padding:12px 14px;display:flex;flex-direction:column;gap:8px;flex:0 0 180px;border-right:1px solid}
.qcard.teal .insights{border-color:#9FE1CB}
.qcard.blue .insights{border-color:#B5D4F4}
.qcard.green .insights{border-color:#C0DD97}

.ins-row{display:flex;align-items:center;gap:7px}
.ins-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot-teal{background:#1D9E75}
.dot-blue{background:#185FA5}
.dot-green{background:#3B6D11}
.ins-val{font-size:13px;font-weight:500;color:var(--color-text-primary);line-height:1.1}
.ins-lbl{font-size:10px;color:var(--color-text-secondary)}

.chart-area{padding:12px 14px;flex:1;min-width:0}
.chart-lbl{font-size:10px;font-weight:500;color:var(--color-text-secondary);margin-bottom:7px}

.bars{display:flex;flex-direction:column;gap:4px}
.bar-row{display:flex;align-items:center;gap:6px}
.bar-key{font-size:10px;color:var(--color-text-secondary);text-align:left;flex-shrink:0}
.bar-track{flex:1;height:13px;border-radius:3px;overflow:hidden}
.bar-track.teal-bg{background:#9FE1CB}
.bar-track.blue-bg{background:#B5D4F4}
.bar-track.green-bg{background:#C0DD97}
.bar-fill{height:100%;border-radius:3px}
.fill-teal{background:#1D9E75}
.fill-teal-pk{background:#085041}
.fill-blue{background:#185FA5}
.fill-blue-pk{background:#0C447C}
.fill-green{background:#3B6D11}
.fill-green-pk{background:#173404}
.bar-annot{font-size:9px;color:var(--color-text-secondary);min-width:56px}

.bubbles{display:flex;align-items:flex-end;gap:6px;height:66px}
.bub-col{display:flex;flex-direction:column;align-items:center;gap:3px}
.bub{border-radius:50%;display:flex;align-items:center;justify-content:center}
.bub span{font-size:8px;font-weight:500;color:#fff}
.bub-id{font-size:8px;color:var(--color-text-secondary)}

.heatgrid{display:flex;flex-wrap:wrap;gap:3px}
.hcell{width:13px;height:13px;border-radius:2px;cursor:default}

.section-sep{height:1px;background:var(--color-border-tertiary);margin:4px 0 24px}
</style>

